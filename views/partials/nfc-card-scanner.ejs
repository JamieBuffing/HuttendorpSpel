<div class="nfcScanner yesPhone" data-card-scanner-status-wrap>
  <p class="nfcScannerStatus" data-card-scanner-status>Wachten op NFC scanner...</p>
  <small data-card-scanner-debug hidden></small>
  <button type="button" data-card-scanner-test hidden>Test UID invullen</button>
</div>

<script>
  (() => {
    const inputName = '<%= inputName %>'
    const autoSubmit = <%= autoSubmit ? 'true' : 'false' %>
    const status = document.querySelector('[data-card-scanner-status]')
    const debugEl = document.querySelector('[data-card-scanner-debug]')
    const testButton = document.querySelector('[data-card-scanner-test]')
    const input = document.querySelector(`input[name="${inputName}"]:not([type="hidden"])`)
    const nfcDebug = new URLSearchParams(window.location.search).get('nfcDebug') === '1'

    if (!input) return

    const state = {
      lastUid: '',
      lastUidAt: 0
    }

    const setStatus = (message) => {
      if (status) status.textContent = message
    }

    const fillCardInput = (cardId, source) => {
      const cleanCardId = String(cardId || '').trim()
      if (!cleanCardId) return

      input.value = cleanCardId
      input.dispatchEvent(new Event('input', { bubbles: true }))
      input.dispatchEvent(new Event('change', { bubbles: true }))

      document.querySelectorAll(`input[type="hidden"][name="${inputName}"]`).forEach((hiddenInput) => {
        hiddenInput.value = cleanCardId
      })

      setStatus(`${source}: ${cleanCardId}`)

      if (autoSubmit && input.form) {
        input.form.submit()
      }
    }

    const handleRemoteCard = (uid) => {
      const cleanUid = String(uid || '').trim().toUpperCase()
      if (!cleanUid) return

      const now = Date.now()
      if (state.lastUid === cleanUid && now - state.lastUidAt < 1000) return

      state.lastUid = cleanUid
      state.lastUidAt = now
      fillCardInput(cleanUid, 'Kaart gescand')
    }

    window.fillCardInputFromScan = fillCardInput

    startKeyboardScanner(fillCardInput)
    startMobileNfcScanner(fillCardInput, setStatus)

    if (nfcDebug && testButton) {
      testButton.hidden = false
      testButton.addEventListener('click', () => {
        fillCardInput('TEST-UID', 'Debug test')
      })
    }

    function startKeyboardScanner(onScan) {
      let buffer = ''
      let lastKeyAt = 0
      const maxGapMs = 80
      const minScanLength = 3

      document.addEventListener('keydown', (event) => {
        if (event.ctrlKey || event.altKey || event.metaKey) return

        const now = Date.now()
        const gap = now - lastKeyAt

        if (gap > maxGapMs) {
          buffer = ''
        }

        lastKeyAt = now

        if (event.key === 'Enter' || event.key === 'Tab') {
          const scannedValue = buffer.trim()
          buffer = ''

          if (scannedValue.length >= minScanLength) {
            event.preventDefault()
            onScan(scannedValue, 'Scanner gelezen')
          }

          return
        }

        if (event.key.length !== 1) return
        buffer += event.key
      }, true)
    }

    function startMobileNfcScanner(onScan, setStatus) {
      if (!('NDEFReader' in window)) {
        return
      }

      if (!window.isSecureContext) {
        return
      }

      let isStarting = false
      let hasStarted = false

      const startNfc = async () => {
        if (hasStarted || isStarting) return

        isStarting = true

        try {
          const ndef = new NDEFReader()
          await ndef.scan()

          hasStarted = true
          setStatus('NFC telefoonlezer staat aan. Houd een kaart tegen je telefoon.')

          ndef.addEventListener('reading', (event) => {
            const cardId = getCardIdFromNfcEvent(event)

            if (!cardId) {
              setStatus('Kaart gelezen, maar geen kaart ID gevonden.')
              return
            }

            onScan(cardId, 'NFC gelezen')
          })
        } catch (error) {
          if (nfcDebug) {
            setStatus(error.message || 'NFC kon niet gestart worden.')
          }
        } finally {
          isStarting = false
        }
      }

      startNfc()

      ;['pointerdown', 'touchstart', 'click', 'keydown'].forEach((eventName) => {
        document.addEventListener(eventName, startNfc, { once: false, passive: true })
      })
    }

    function getCardIdFromNfcEvent(event) {
      for (const record of event.message.records) {
        if (record.recordType === 'text') {
          return new TextDecoder(record.encoding || 'utf-8').decode(record.data).trim()
        }

        if (record.recordType === 'url') {
          return new TextDecoder().decode(record.data).trim()
        }
      }

      return event.serialNumber || ''
    }
  })()
</script>

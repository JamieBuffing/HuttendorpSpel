');
const DATA_ROWS = [
  { x:4, y:4, bits:13 },
  { x:4, y:13, bits:15 },
  { x:4, y:22, bits:15 },
  { x:4, y:31, bits:15 },
  { x:4, y:40, bits:15 },
  { x:4, y:49, bits:15 }
];
const MAX_BITS = 88;
let lastDecoded = null;
const video = document.getElementById('video');
const canvas = document.getElementById('canvas');
const ctx = canvas.getContext('2d', { willReadFrequently: true });
const debug = document.getElementById('debug');
const dctx = debug.getContext('2d');
const statusEl = document.getElementById('status');
const payloadEl = document.getElementById('payload');
const decodedEl = document.getElementById('decoded');
const submitBtn = document.getElementById('submitBtn');
function setStatus(text) { statusEl.textContent = text; }
function isLit(r,g,b) {
  const brightness = (r+g+b)/3;
  const blueBoost = b > 55 && b > r * 0.7 && b > g * 0.7;
  return brightness > 85 || blueBoost;
}
function sampleLit(data, w, h, x, y, ww, hh) {
  let lit=0,total=0;
  const x0=Math.max(0, Math.floor(x));
  const y0=Math.max(0, Math.floor(y));
  const x1=Math.min(w, Math.ceil(x+ww));
  const y1=Math.min(h, Math.ceil(y+hh));
  for(let yy=y0; yy<y1; yy++) {
    for(let xx=x0; xx<x1; xx++) {
      const i=(yy*w+xx)*4;
      if(isLit(data[i],data[i+1],data[i+2])) lit++;
      total++;
    }
  }
  return total ? lit/total : 0;
}
function findLitBounds(img) {
  const data=img.data,w=img.width,h=img.height;
  let minX=w,minY=h,maxX=0,maxY=0,count=0;
  for(let y=0;y<h;y+=2) {
    for(let x=0;x<w;x+=2) {
      const i=(y*w+x)*4;
      if(isLit(data[i],data[i+1],data[i+2])) {
        minX=Math.min(minX,x); minY=Math.min(minY,y); maxX=Math.max(maxX,x); maxY=Math.max(maxY,y); count++;
      }
    }
  }
  if(count<50) return null;
  return {minX,minY,maxX,maxY,count};
}
function hexFromNibble(v) { return v<10 ? String(v) : String.fromCharCode(65+v-10); }
function checksum(data) {
  let total=0;
  for(const ch of data) total += ch.charCodeAt(0);
  return hexFromNibble(total % 16);
}
function bitsToChars(bits) {
  let out='';
  for(let i=0;i+3<bits.length;i+=4) {
    const v=parseInt(bits.slice(i,i+4),2);
    out += hexFromNibble(v);
  }
  return out;
}
function decodeChars(chars) {
  // Zoek langste prefix waarbij volgende teken checksum is; de rest is padding 0.
  for(let end=chars.length-2; end>=4; end--) {
    const raw=chars.slice(0,end+1);
    const check=chars[end+1];
    const rest=chars.slice(end+2);
    if(checksum(raw)===check && /^0*$/.test(rest)) {
      const postId=raw.slice(0,3).toLowerCase();
      const answer=raw.slice(3,4);
      const uid=raw.slice(4);
      if(['R','G','B'].includes(answer) && uid.length>0) {
        return { postId, answer, uid, payload: raw+check };
      }
    }
  }
  return null;
}
function normalizeAndRead(img) {
  const bounds=findLitBounds(img);
  if(!bounds) throw new Error('Geen OLED pixels gevonden');
  const padX=(bounds.maxX-bounds.minX)*0.03;
  const padY=(bounds.maxY-bounds.minY)*0.03;
  const sx=bounds.minX-padX, sy=bounds.minY-padY;
  const sw=(bounds.maxX-bounds.minX)+padX*2;
  const sh=(bounds.maxY-bounds.minY)+padY*2;
  dctx.fillStyle='black'; dctx.fillRect(0,0,128,64);
  dctx.drawImage(canvas, sx, sy, sw, sh, 0, 0, 128, 64);
  const norm=dctx.getImageData(0,0,128,64);
  // Simpele referentiecheck: genoeg W-punten aanwezig
  let ref=0,refTotal=0;
  for(let y=0;y<64;y++) {
    for(let x=0;x<128;x++) {
      if(PIXELMAP[y][x]==='W') {
        const ratio=sampleLit(norm.data,128,64,x,y,1,1);
        if(ratio>0.1) ref++;
        refTotal++;
      }
    }
  }
  if(ref/refTotal < 0.35) throw new Error('OLED-rand/hoek niet duidelijk genoeg');
  let bits='';
  for(const row of DATA_ROWS) {
    for(let b=0;b<row.bits;b++) {
      const ratio=sampleLit(norm.data,128,64,row.x+b*8+1,row.y+1,6,6);
      bits += ratio > 0.35 ? '1':'0';
    }
  }
  const chars=bitsToChars(bits);
  const decoded=decodeChars(chars);
  if(!decoded) throw new Error('Checksum fout of code niet scherp genoeg: '+chars);
  return decoded;
}
async function startCamera() {
  const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: { ideal:'environment' } }, audio:false });
  video.srcObject = stream;
  setStatus('Camera gestart. Richt op de OLED-code en klik scan.');
}
function scanFrame() {
  if(!video.videoWidth) throw new Error('Camera nog niet klaar');
  canvas.width=video.videoWidth; canvas.height=video.videoHeight;
  ctx.drawImage(video,0,0,canvas.width,canvas.height);
  const img=ctx.getImageData(0,0,canvas.width,canvas.height);
  const decoded=normalizeAndRead(img);
  lastDecoded=decoded;
  payloadEl.textContent=decoded.payload;
  decodedEl.textContent=`postId=${decoded.postId} uid=${decoded.uid} answer=${decoded.answer}`;
  submitBtn.disabled=false;
  setStatus('Code gelezen. Klik importeer.');
}
async function submitDecoded() {
  if(!lastDecoded) return;
  const res=await fetch('/import/scan-code', {
    method:'POST',
    headers: { 'Content-Type':'application/json' },
    body: JSON.stringify(lastDecoded)
  });
  const json=await res.json();
  if(json.ok || json.alreadyAnswered) setStatus(json.alreadyAnswered ? 'Al gedaan / stond al in database.' : 'Geïmporteerd.');
  else setStatus('Fout: '+(json.error || 'onbekend'));
}
document.getElementById('startBtn').addEventListener('click', () => startCamera().catch(e => setStatus(e.message)));
document.getElementById('scanBtn').addEventListener('click', () => { try { scanFrame(); } catch(e) { setStatus(e.message); } });
submitBtn.addEventListener('click', () => submitDecoded().catch(e => setStatus(e.message)));
</script>


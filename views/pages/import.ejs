<%- include('../partials/page-shell-start', { title: 'Backup import' }); %>

<section class="panel backupImportPanel">
  <h1>Backup import</h1>
  <p>Scan de OLED-pixelmapcode van een ESP32-box. Wit is herkenning, blauw/licht is data, zwart is achtergrond.</p>

  <% if (error) { %>
    <p class="error"><%= error %></p>
  <% } %>

  <div class="scannerGrid">
    <div>
      <div class="videoBox">
        <video id="video" playsinline muted></video>
        <canvas id="scanCanvas" width="640" height="360"></canvas>
        <div class="scanOverlay">Plaats de OLED-code groot en recht in beeld</div>
      </div>

      <div class="buttonRow">
        <button class="button" type="button" id="startCamera">Camera starten</button>
        <button class="button" type="button" id="scanOnce">Scan frame</button>
        <button class="button secondary" type="button" id="toggleAuto">Auto scan: uit</button>
      </div>
    </div>

    <div class="statusCard">
      <h2>Status</h2>
      <p id="scanStatus">Camera nog niet gestart.</p>
      <p id="scanDebug" class="helpText"></p>
      <form method="post" action="/import" class="formStack">
        <label>Handmatig bitstring plakken
          <textarea id="manualCode" name="bitString" rows="7" placeholder="010101..."></textarea>
        </label>
        <button class="button" type="submit">Handmatig importeren</button>
      </form>
    </div>
  </div>
</section>

<% if (result) { %>
  <section class="panel">
    <h2>Import resultaat</h2>
    <table class="dataTable">
      <thead>
        <tr>
          <th>Status</th>
          <th>Post</th>
          <th>UID</th>
          <th>Antwoord</th>
          <th>Melding</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><%= result.result?.ok ? 'Opgeslagen' : (result.result?.alreadyAnswered ? 'Al gedaan' : 'Niet opgeslagen') %></td>
          <td><%= result.decoded?.postId || '-' %></td>
          <td><%= result.decoded?.uid || '-' %></td>
          <td><%= result.decoded?.answer || '-' %></td>
          <td><%= result.result?.questionTitle || result.result?.error || '-' %></td>
        </tr>
      </tbody>
    </table>
  </section>
<% } %>

<style>
  .scannerGrid { display:grid; grid-template-columns: 1.3fr .7fr; gap: 1rem; align-items:start; }
  .videoBox { position:relative; border: 1px solid rgba(255,255,255,.25); border-radius: 18px; overflow:hidden; background:#000; min-height: 260px; }
  #video, #scanCanvas { width:100%; display:block; background:#000; }
  #scanCanvas { position:absolute; inset:0; pointer-events:none; }
  .scanOverlay { position:absolute; left:5%; right:5%; bottom:1rem; text-align:center; padding:.65rem; border-radius: 999px; background:rgba(0,0,0,.58); color:#86efac; font-weight:700; }
  .buttonRow { display:flex; gap:.75rem; flex-wrap:wrap; margin-top:1rem; }
  .statusCard { border:1px solid rgba(255,255,255,.18); border-radius:18px; padding:1rem; }
  .statusOk { color:#86efac; font-weight:800; }
  .statusWarn { color:#fbbf24; font-weight:800; }
  .statusError { color:#f87171; font-weight:800; }
  @media(max-width: 800px) { .scannerGrid { grid-template-columns:1fr; } }
</style>

<script>
const video = document.getElementById('video');
const canvas = document.getElementById('scanCanvas');
const ctx = canvas.getContext('2d', { willReadFrequently: true });
const scanStatus = document.getElementById('scanStatus');
const scanDebug = document.getElementById('scanDebug');
const manualCode = document.getElementById('manualCode');
const startCamera = document.getElementById('startCamera');
const scanOnce = document.getElementById('scanOnce');
const toggleAuto = document.getElementById('toggleAuto');
const DATA_ZONES = <%- JSON.stringify(zones) %>;
let stream = null;
let autoScan = false;
let busy = false;
let lastSubmitAt = 0;

function setStatus(message, type = 'warn') {
  scanStatus.className = type === 'ok' ? 'statusOk' : type === 'error' ? 'statusError' : 'statusWarn';
  scanStatus.textContent = message;
}

function isLitPixel(r, g, b) {
  const brightness = (r + g + b) / 3;
  const blueStrong = b > 70 && b > r * 0.75 && b > g * 0.75;
  return brightness > 85 || blueStrong;
}

function drawVideoFrame() {
  if (!video.videoWidth || !video.videoHeight) return null;

  const box = canvas.getBoundingClientRect();
  const ratio = video.videoWidth / video.videoHeight;
  let w = canvas.width;
  let h = Math.round(w / ratio);
  if (h > canvas.height) { h = canvas.height; w = Math.round(h * ratio); }
  const x = Math.floor((canvas.width - w) / 2);
  const y = Math.floor((canvas.height - h) / 2);

  ctx.clearRect(0, 0, canvas.width, canvas.height);
  ctx.drawImage(video, x, y, w, h);
  return ctx.getImageData(0, 0, canvas.width, canvas.height);
}

function findLitBoundingBox(image) {
  let minX = image.width, minY = image.height, maxX = -1, maxY = -1;
  const data = image.data;

  for (let y = 0; y < image.height; y += 2) {
    for (let x = 0; x < image.width; x += 2) {
      const i = (y * image.width + x) * 4;
      if (isLitPixel(data[i], data[i + 1], data[i + 2])) {
        if (x < minX) minX = x;
        if (y < minY) minY = y;
        if (x > maxX) maxX = x;
        if (y > maxY) maxY = y;
      }
    }
  }

  if (maxX < minX || maxY < minY) return null;

  // Beetje marge omdat we met stappen van 2 scannen.
  minX = Math.max(0, minX - 4); minY = Math.max(0, minY - 4);
  maxX = Math.min(image.width - 1, maxX + 4); maxY = Math.min(image.height - 1, maxY + 4);

  const w = maxX - minX + 1;
  const h = maxY - minY + 1;
  const aspect = w / Math.max(h, 1);

  if (w < 80 || h < 35 || aspect < 1.45 || aspect > 2.55) return null;
  return { x: minX, y: minY, w, h };
}

function litRatio(image, x0, y0, w, h) {
  let lit = 0, total = 0;
  const data = image.data;
  const sx = Math.max(0, Math.floor(x0));
  const sy = Math.max(0, Math.floor(y0));
  const ex = Math.min(image.width, Math.ceil(x0 + w));
  const ey = Math.min(image.height, Math.ceil(y0 + h));

  for (let y = sy; y < ey; y++) {
    for (let x = sx; x < ex; x++) {
      const i = (y * image.width + x) * 4;
      if (isLitPixel(data[i], data[i + 1], data[i + 2])) lit++;
      total++;
    }
  }
  return total ? lit / total : 0;
}

function readBitsFromBox(image, box) {
  let bits = '';
  for (const z of DATA_ZONES) {
    for (let col = 0; col < z.w; col++) {
      const px = box.x + ((z.x + col + 0.5) / 128) * box.w;
      const py = box.y + ((z.y + 0.5) / 64) * box.h;
      const pw = Math.max(1, box.w / 128 * 0.9);
      const ph = Math.max(2, box.h / 64 * (z.h - 1));
      const ratio = litRatio(image, px - pw / 2, py, pw, ph);
      bits += ratio > 0.33 ? '1' : '0';
    }
  }
  return bits;
}

function drawDebugBox(box) {
  ctx.strokeStyle = '#22c55e';
  ctx.lineWidth = 3;
  ctx.strokeRect(box.x, box.y, box.w, box.h);
  for (const z of DATA_ZONES) {
    ctx.strokeStyle = 'rgba(59,130,246,.8)';
    ctx.lineWidth = 1;
    ctx.strokeRect(
      box.x + z.x / 128 * box.w,
      box.y + z.y / 64 * box.h,
      z.w / 128 * box.w,
      z.h / 64 * box.h
    );
  }
}

async function submitBits(bitString) {
  if (busy || Date.now() - lastSubmitAt < 1800) return;
  busy = true;
  lastSubmitAt = Date.now();
  manualCode.value = bitString;

  try {
    const response = await fetch('/import/scan-code', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ bitString })
    });
    const json = await response.json();
    if (!response.ok || !json.ok) throw new Error(json.error || 'Import mislukt');

    if (json.alreadyAnswered) {
      setStatus('Al gedaan: stond al in de database.', 'ok');
    } else {
      setStatus('Backup geïmporteerd: ' + json.decoded.postId + ' / ' + json.decoded.uid + ' / ' + json.decoded.answer, 'ok');
    }
  } catch (error) {
    setStatus(error.message || 'Code niet geldig', 'error');
  } finally {
    busy = false;
  }
}

function scanFrame() {
  const image = drawVideoFrame();
  if (!image) return;
  const box = findLitBoundingBox(image);
  if (!box) { setStatus('Geen OLED-code gevonden. Houd hem groter/rechter in beeld.', 'warn'); return; }
  drawDebugBox(box);
  const bits = readBitsFromBox(image, box);
  scanDebug.textContent = 'Box: ' + Math.round(box.w) + '×' + Math.round(box.h) + ' px, bits: ' + bits.length;
  submitBits(bits);
}

startCamera.addEventListener('click', async () => {
  try {
    stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: { ideal: 'environment' } }, audio: false });
    video.srcObject = stream;
    await video.play();
    setStatus('Camera gestart. Richt op de OLED-code.', 'ok');
  } catch (error) {
    setStatus('Camera starten mislukt: ' + error.message, 'error');
  }
});

scanOnce.addEventListener('click', scanFrame);
toggleAuto.addEventListener('click', () => {
  autoScan = !autoScan;
  toggleAuto.textContent = 'Auto scan: ' + (autoScan ? 'aan' : 'uit');
});

setInterval(() => { if (autoScan && stream) scanFrame(); }, 900);
</script>

<%- include('../partials/page-shell-end'); %>

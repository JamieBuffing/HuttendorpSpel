<%- include('../partials/page-shell-start', { title: 'QR backup scanner' }); %>

<section class="panel">
  <h1>QR backup scanner</h1>
  <p>Scan de QR-code op het OLED-scherm. De code heeft dit formaat: <code>P01R042A16BAFC2091</code>.</p>

  <% if (error) { %>
    <p class="error"><%= error %></p>
  <% } %>

  <% if (result) { %>
    <section class="notice success">
      <h2>Import verwerkt</h2>
      <p><strong>Post:</strong> <%= result.decoded.postId %></p>
      <p><strong>Antwoord:</strong> <%= result.decoded.answer %></p>
      <p><strong>UID:</strong> <%= result.decoded.uid %></p>
    </section>
  <% } %>
</section>

<section class="panel qrScannerPanel">
  <div class="sectionHeader">
    <div>
      <h2>Camera scanner</h2>
      <p>Richt de camera op de QR-code. Je hoeft geen kader precies te raken; de QR-library zoekt de code zelf.</p>
    </div>
  </div>

  <div class="scannerControls">
    <button class="button" id="startScanner" type="button">Camera starten</button>
    <button class="button secondary" id="stopScanner" type="button" disabled>Stoppen</button>
    <label class="checkboxLine"><input type="checkbox" id="testOnly" checked> Alleen testen/lezen, nog niet opslaan</label>
  </div>

  <div class="qrVideoWrap">
    <video id="qrVideo" muted playsinline></video>
  </div>

  <div class="scanStatus" id="scanStatus">Nog geen scan.</div>
  <pre class="scanDebug" id="scanDebug"></pre>
</section>

<section class="panel">
  <h2>Handmatig invoeren</h2>
  <form method="post" action="/import" class="gridForm two">
    <label>Code
      <input name="code" id="manualCode" placeholder="P01R042A16BAFC2091" autocomplete="off">
    </label>
    <button class="button" type="submit">Code importeren</button>
  </form>
</section>

<style>
  .qrScannerPanel video { width: 100%; max-height: 70vh; background: #000; border-radius: 16px; object-fit: cover; }
  .qrVideoWrap { overflow: hidden; border-radius: 16px; border: 1px solid rgba(255,255,255,.15); background:#000; }
  .scannerControls { display:flex; flex-wrap:wrap; gap:10px; align-items:center; margin:12px 0; }
  .checkboxLine { display:flex; align-items:center; gap:8px; }
  .scanStatus { margin-top:12px; padding:12px; border-radius:12px; background:rgba(255,255,255,.08); font-weight:700; }
  .scanStatus.ok { background:rgba(0,180,90,.16); }
  .scanStatus.warn { background:rgba(255,180,0,.18); }
  .scanStatus.error { background:rgba(255,0,0,.14); }
  .scanDebug { white-space:pre-wrap; overflow-wrap:anywhere; background:rgba(0,0,0,.35); padding:12px; border-radius:12px; min-height:70px; }
</style>

<script type="module">
  import QrScanner from 'https://cdn.jsdelivr.net/npm/qr-scanner@1.4.2/qr-scanner.min.js';

  const video = document.getElementById('qrVideo');
  const statusEl = document.getElementById('scanStatus');
  const debugEl = document.getElementById('scanDebug');
  const startBtn = document.getElementById('startScanner');
  const stopBtn = document.getElementById('stopScanner');
  const testOnlyEl = document.getElementById('testOnly');
  const manualCodeEl = document.getElementById('manualCode');

  let scanner = null;
  let lastCode = '';
  let stableCount = 0;
  let busy = false;

  function setStatus(text, cls = '') {
    statusEl.textContent = text;
    statusEl.className = 'scanStatus' + (cls ? ' ' + cls : '');
  }

  function normalizeCode(raw) {
    return String(raw || '').toUpperCase().replace(/[^A-Z0-9]/g, '');
  }

  function decodeCode(raw) {
    const code = normalizeCode(raw);
    const match = code.match(/^(P\d{2})([RGB])([0-9A-F]{4,32})$/);
    if (!match) {
      throw new Error('Ongeldig formaat. Verwacht bijvoorbeeld P01R042A16BAFC2091');
    }
    return { code, postId: match[1].toLowerCase(), answer: match[2], uid: match[3] };
  }

  async function submitCode(decoded) {
    const response = await fetch('/import/scan-code', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ code: decoded.code, testOnly: testOnlyEl.checked })
    });
    const json = await response.json().catch(() => ({}));
    if (!response.ok || !json.ok) {
      throw new Error(json.error || 'Opslaan is mislukt.');
    }
    return json;
  }

  async function onScan(result) {
    const raw = typeof result === 'string' ? result : result?.data;
    let decoded;
    try {
      decoded = decodeCode(raw);
    } catch (error) {
      setStatus(error.message, 'error');
      debugEl.textContent = `Gelezen: ${raw || '(leeg)'}`;
      return;
    }

    if (decoded.code === lastCode) stableCount += 1;
    else { lastCode = decoded.code; stableCount = 1; }

    manualCodeEl.value = decoded.code;
    debugEl.textContent = JSON.stringify({ gelezen: decoded.code, postId: decoded.postId, antwoord: decoded.answer, uid: decoded.uid, stabiel: stableCount, testOnly: testOnlyEl.checked }, null, 2);

    if (stableCount < 2) {
      setStatus(`QR gezien: ${decoded.code} — nog 1 stabiele scan nodig`, 'warn');
      return;
    }

    if (busy) return;
    busy = true;
    try {
      const saved = await submitCode(decoded);
      if (testOnlyEl.checked) {
        setStatus(`TEST OK: ${decoded.code}`, 'ok');
      } else {
        setStatus(saved.alreadyAnswered ? `Al bekend: ${decoded.code}` : `Opgeslagen: ${decoded.code}`, 'ok');
      }
    } catch (error) {
      setStatus(error.message, 'error');
    } finally {
      setTimeout(() => { busy = false; stableCount = 0; lastCode = ''; }, 900);
    }
  }

  async function startScanner() {
    if (scanner) return;
    scanner = new QrScanner(video, onScan, {
      preferredCamera: 'environment',
      returnDetailedScanResult: true,
      highlightScanRegion: true,
      highlightCodeOutline: true,
      maxScansPerSecond: 8
    });
    await scanner.start();
    startBtn.disabled = true;
    stopBtn.disabled = false;
    setStatus('Camera actief. Richt op de OLED QR-code.');
  }

  function stopScanner() {
    if (!scanner) return;
    scanner.stop();
    scanner.destroy();
    scanner = null;
    startBtn.disabled = false;
    stopBtn.disabled = true;
    setStatus('Scanner gestopt.');
  }

  startBtn.addEventListener('click', () => startScanner().catch(error => setStatus(error.message || 'Camera starten mislukt.', 'error')));
  stopBtn.addEventListener('click', stopScanner);
</script>

<%- include('../partials/page-shell-end'); %>

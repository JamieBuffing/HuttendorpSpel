<%- include('../partials/page-shell-start', { title: 'QR backup scanner' }); %>

<section class="panel">
  <h1>QR backup scanner</h1>
  <p>Scan de QR-code op het OLED-scherm. Formaat: <code>P01R042A16BAFC2091</code>.</p>

  <% if (error) { %>
    <p class="error"><%= error %></p>
  <% } %>

  <% if (result) { %>
    <section class="notice success">
      <h2>Import verwerkt</h2>
      <p><strong>Post:</strong> <%= result.decoded.postId %></p>
      <p><strong>Antwoord:</strong> <%= result.decoded.answer %></p>
      <p><strong>UID:</strong> <%= result.decoded.uid %></p>
    </section>
  <% } %>
</section>

<section class="panel qrScannerPanel">
  <div class="sectionHeader">
    <div>
      <h2>Camera scanner</h2>
      <p>Druk op <strong>Scan code</strong>. Na een veilige scan verschijnt <strong>Opslaan</strong>. Daarna kun je direct de volgende code scannen.</p>
    </div>
  </div>

  <div class="scannerControls">
    <button class="button" id="scanBtn" type="button">Scan code</button>
    <button class="button successButton" id="saveScanBtn" type="button" hidden>Opslaan</button>
    <button class="button secondary" id="cancelScanBtn" type="button" hidden>Opnieuw scannen</button>
  </div>

  <div class="qrVideoWrap" id="videoWrap" hidden>
    <video id="qrVideo" muted playsinline></video>
  </div>

  <div class="scanStatus" id="scanStatus">Druk op “Scan code”.</div>

  <div class="scanResultCard" id="scanResultCard" hidden>
    <h3>Gevonden code</h3>
    <p class="bigCode" id="foundCode"></p>
    <dl>
      <div><dt>Post</dt><dd id="foundPost"></dd></div>
      <div><dt>Antwoord</dt><dd id="foundAnswer"></dd></div>
      <div><dt>UID</dt><dd id="foundUid"></dd></div>
    </dl>
  </div>
</section>

<section class="panel">
  <h2>Handmatig invoeren</h2>
  <p>Werkt de camera niet? Vul dezelfde code handmatig in en sla hem direct op.</p>
  <form method="post" action="/import" class="gridForm two">
    <label>Code
      <input name="code" id="manualCode" placeholder="P01R042A16BAFC2091" autocomplete="off" inputmode="text">
    </label>
    <button class="button" type="submit">Handmatig opslaan</button>
  </form>
</section>

<style>
  .qrScannerPanel video { width: 100%; max-height: 70vh; background: #000; border-radius: 16px; object-fit: cover; }
  .qrVideoWrap { overflow: hidden; border-radius: 16px; border: 1px solid rgba(255,255,255,.15); background:#000; margin-top: 12px; }
  .scannerControls { display:flex; flex-wrap:wrap; gap:10px; align-items:center; margin:12px 0; }
  .scanStatus { margin-top:12px; padding:12px; border-radius:12px; background:rgba(255,255,255,.08); font-weight:700; }
  .scanStatus.ok { background:rgba(0,180,90,.16); }
  .scanStatus.warn { background:rgba(255,180,0,.18); }
  .scanStatus.error { background:rgba(255,0,0,.14); }
  .scanResultCard { margin-top: 14px; padding: 14px; border-radius: 14px; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.12); }
  .scanResultCard h3 { margin-top: 0; }
  .bigCode { font-size: clamp(1.1rem, 3vw, 1.7rem); font-weight: 900; letter-spacing: .04em; overflow-wrap: anywhere; }
  .scanResultCard dl { display: grid; gap: 8px; margin: 0; }
  .scanResultCard dl div { display: grid; grid-template-columns: 110px 1fr; gap: 10px; }
  .scanResultCard dt { opacity: .75; }
  .scanResultCard dd { margin: 0; font-weight: 800; overflow-wrap: anywhere; }
  .successButton { background: #18a558; }
</style>

<script type="module">
  import QrScanner from 'https://cdn.jsdelivr.net/npm/qr-scanner@1.4.2/qr-scanner.min.js';

  const video = document.getElementById('qrVideo');
  const videoWrap = document.getElementById('videoWrap');
  const statusEl = document.getElementById('scanStatus');
  const scanBtn = document.getElementById('scanBtn');
  const saveScanBtn = document.getElementById('saveScanBtn');
  const cancelScanBtn = document.getElementById('cancelScanBtn');
  const manualCodeEl = document.getElementById('manualCode');
  const scanResultCard = document.getElementById('scanResultCard');
  const foundCode = document.getElementById('foundCode');
  const foundPost = document.getElementById('foundPost');
  const foundAnswer = document.getElementById('foundAnswer');
  const foundUid = document.getElementById('foundUid');

  let scanner = null;
  let lastCode = '';
  let stableCount = 0;
  let safeDecoded = null;
  let saving = false;

  function setStatus(text, cls = '') {
    statusEl.textContent = text;
    statusEl.className = 'scanStatus' + (cls ? ' ' + cls : '');
  }

  function normalizeCode(raw) {
    return String(raw || '').toUpperCase().replace(/[^A-Z0-9]/g, '');
  }

  function decodeCode(raw) {
    const code = normalizeCode(raw);
    const match = code.match(/^(P\d{2})([RGB])([0-9A-F]{4,32})$/);
    if (!match) throw new Error('Ongeldig formaat. Verwacht bijvoorbeeld P01R042A16BAFC2091');
    return { code, postId: match[1].toLowerCase(), answer: match[2], uid: match[3] };
  }

  function showSafeScan(decoded) {
    safeDecoded = decoded;
    manualCodeEl.value = decoded.code;
    foundCode.textContent = decoded.code;
    foundPost.textContent = decoded.postId;
    foundAnswer.textContent = decoded.answer;
    foundUid.textContent = decoded.uid;
    scanResultCard.hidden = false;
    scanBtn.hidden = true;
    saveScanBtn.hidden = false;
    cancelScanBtn.hidden = false;
    videoWrap.hidden = true;
    setStatus('Veilige scan gevonden. Controleer kort en druk op Opslaan.', 'ok');
  }

  async function stopScannerOnly() {
    if (!scanner) return;
    scanner.stop();
    scanner.destroy();
    scanner = null;
  }

  async function resetForNextScan(message = 'Klaar voor de volgende code.') {
    await stopScannerOnly();
    lastCode = '';
    stableCount = 0;
    safeDecoded = null;
    saving = false;
    scanResultCard.hidden = true;
    videoWrap.hidden = true;
    scanBtn.hidden = false;
    scanBtn.disabled = false;
    saveScanBtn.hidden = true;
    saveScanBtn.disabled = false;
    cancelScanBtn.hidden = true;
    setStatus(message);
  }

  async function onScan(result) {
    const raw = typeof result === 'string' ? result : result?.data;
    let decoded;
    try {
      decoded = decodeCode(raw);
    } catch (error) {
      setStatus(error.message, 'error');
      return;
    }

    if (decoded.code === lastCode) stableCount += 1;
    else { lastCode = decoded.code; stableCount = 1; }

    if (stableCount < 2) {
      setStatus(`QR gezien: ${decoded.code} — nog 1 veilige scan nodig`, 'warn');
      return;
    }

    await stopScannerOnly();
    showSafeScan(decoded);
  }

  async function startScanner() {
    await resetForNextScan('Camera wordt gestart...');
    scanBtn.disabled = true;
    videoWrap.hidden = false;
    scanner = new QrScanner(video, onScan, {
      preferredCamera: 'environment',
      returnDetailedScanResult: true,
      highlightScanRegion: true,
      highlightCodeOutline: true,
      maxScansPerSecond: 10
    });
    await scanner.start();
    setStatus('Camera actief. Richt op de OLED QR-code.');
  }

  async function saveSafeScan() {
    if (!safeDecoded || saving) return;
    saving = true;
    saveScanBtn.disabled = true;
    setStatus('Opslaan...', 'warn');

    try {
      const response = await fetch('/import/scan-code', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code: safeDecoded.code })
      });
      const json = await response.json().catch(() => ({}));
      if (!response.ok || !json.ok) throw new Error(json.error || 'Opslaan is mislukt.');
      await resetForNextScan(json.alreadyAnswered ? `Al bekend: ${safeDecoded.code}` : `Opgeslagen: ${safeDecoded.code}`);
    } catch (error) {
      saving = false;
      saveScanBtn.disabled = false;
      setStatus(error.message || 'Opslaan is mislukt.', 'error');
    }
  }

  scanBtn.addEventListener('click', () => startScanner().catch(error => resetForNextScan(error.message || 'Camera starten mislukt.')));
  saveScanBtn.addEventListener('click', saveSafeScan);
  cancelScanBtn.addEventListener('click', () => resetForNextScan('Scan geannuleerd. Druk op “Scan code” voor een nieuwe scan.'));
</script>

<%- include('../partials/page-shell-end'); %>

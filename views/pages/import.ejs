<%- include('../partials/page-shell-start', { title: 'Backup import scanner' }); %>

<section class="panel">
  <h1>Backup import scanner</h1>
  <p>Scan hier de 6-regel backup-code van het OLED-scherm. Houd het kader van de OLED-code zo recht mogelijk in beeld.</p>

  <% if (error) { %>
    <p class="error"><%= error %></p>
  <% } %>

  <div class="scannerLayout">
    <video id="backupVideo" autoplay playsinline muted style="width:100%;max-width:520px;border-radius:16px;background:#000;"></video>
    <canvas id="backupCanvas" width="640" height="360" style="display:none;"></canvas>

    <div class="formStack" style="margin-top:16px;">
      <button class="button" type="button" id="startCameraBtn">Camera starten</button>
      <button class="button" type="button" id="scanFrameBtn">Scan beeld</button>
      <button class="button secondary" type="button" id="stopCameraBtn">Camera stoppen</button>
    </div>

    <p class="helpText" id="scanStatus">Nog niet gescand.</p>
  </div>
</section>

<section class="panel">
  <h2>Handmatig testen</h2>
  <p class="helpText">Plak hier eventueel de uitgelezen code, bijvoorbeeld <code>P01R042A16BAFC2091D00000</code>.</p>

  <form method="post" action="/import" class="formStack">
    <label>Backup-code
      <input name="code" id="manualCode" placeholder="P01R042A16BAFC2091D00000" autocomplete="off">
    </label>
    <button class="button" type="submit">Code importeren</button>
  </form>
</section>

<% if (decoded || result) { %>
  <section class="panel">
    <h2>Import resultaat</h2>
    <% if (decoded) { %>
      <p>Post: <strong><%= decoded.postId %></strong></p>
      <p>UID: <strong><%= decoded.uid %></strong></p>
      <p>Antwoord: <strong><%= decoded.answer %></strong></p>
    <% } %>

    <% if (result) { %>
      <p>Status: <strong><%= result.ok ? 'Opgeslagen' : (result.alreadyAnswered ? 'Al gedaan' : 'Niet opgeslagen') %></strong></p>
      <p>Team: <strong><%= result.teamName || result.teamId || '-' %></strong></p>
      <p>Melding: <strong><%= result.questionTitle || result.error || '-' %></strong></p>
    <% } %>
  </section>
<% } %>

<script>
  const video = document.getElementById('backupVideo')
  const canvas = document.getElementById('backupCanvas')
  const statusEl = document.getElementById('scanStatus')
  const manualCode = document.getElementById('manualCode')
  const startBtn = document.getElementById('startCameraBtn')
  const scanBtn = document.getElementById('scanFrameBtn')
  const stopBtn = document.getElementById('stopCameraBtn')

  let stream = null

  function valueToChar(value, position) {
    if (position === 0 && value === 14) return 'P'
    if (position === 3) {
      if (value === 13) return 'R'
      if (value === 12) return 'G'
      if (value === 11) return 'B'
    }
    if (value >= 0 && value <= 9) return String(value)
    return String.fromCharCode('A'.charCodeAt(0) + value - 10)
  }

  function decodeBitsToCode(bits) {
    let code = ''
    let position = 0

    for (let row = 0; row < 6; row++) {
      for (let group = 0; group < 4; group++) {
        let value = 0
        for (let bit = 0; bit < 4; bit++) {
          const index = row * 16 + group * 4 + bit
          value = (value << 1) + (bits[index] ? 1 : 0)
        }
        code += valueToChar(value, position)
        position++
      }
    }

    return code
  }

  function readCodeFromCanvas() {
    const ctx = canvas.getContext('2d', { willReadFrequently: true })
    const width = canvas.width
    const height = canvas.height
    const image = ctx.getImageData(0, 0, width, height)
    const data = image.data

    let minX = width, minY = height, maxX = 0, maxY = 0

    for (let y = 0; y < height; y += 2) {
      for (let x = 0; x < width; x += 2) {
        const i = (y * width + x) * 4
        const r = data[i]
        const g = data[i + 1]
        const b = data[i + 2]
        const bright = r + g + b

        if (bright > 540) {
          if (x < minX) minX = x
          if (y < minY) minY = y
          if (x > maxX) maxX = x
          if (y > maxY) maxY = y
        }
      }
    }

    if (maxX <= minX || maxY <= minY || (maxX - minX) < 80 || (maxY - minY) < 40) {
      throw new Error('Geen duidelijk wit kader gevonden')
    }

    const boxW = maxX - minX
    const boxH = maxY - minY
    const bits = []

    for (let row = 0; row < 6; row++) {
      const y = Math.round(minY + boxH * ((3 + row * 9 + 3.5) / 64))
      for (let bit = 0; bit < 16; bit++) {
        const x = Math.round(minX + boxW * ((6 + bit * 3 + 1.5) / 128))
        let brightCount = 0
        let total = 0

        for (let dy = -2; dy <= 2; dy++) {
          for (let dx = -2; dx <= 2; dx++) {
            const sx = Math.max(0, Math.min(width - 1, x + dx))
            const sy = Math.max(0, Math.min(height - 1, y + dy))
            const i = (sy * width + sx) * 4
            const bright = data[i] + data[i + 1] + data[i + 2]
            if (bright > 540) brightCount++
            total++
          }
        }

        bits.push(brightCount > total * 0.35)
      }
    }

    return decodeBitsToCode(bits)
  }

  async function startCamera() {
    stream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: { ideal: 'environment' } },
      audio: false
    })
    video.srcObject = stream
    statusEl.textContent = 'Camera gestart. Richt op de OLED-code en klik op Scan beeld.'
  }

  function stopCamera() {
    if (stream) {
      stream.getTracks().forEach((track) => track.stop())
      stream = null
    }
    video.srcObject = null
    statusEl.textContent = 'Camera gestopt.'
  }

  async function submitCode(code) {
    const response = await fetch('/import/scan-code', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ code })
    })

    const result = await response.json()

    if (!response.ok || !result.ok) {
      throw new Error(result.error || result.result?.error || 'Import mislukt')
    }

    return result
  }

  async function scanFrame() {
    if (!video.videoWidth) {
      statusEl.textContent = 'Camera is nog niet klaar.'
      return
    }

    const ctx = canvas.getContext('2d')
    canvas.width = video.videoWidth
    canvas.height = video.videoHeight
    ctx.drawImage(video, 0, 0, canvas.width, canvas.height)

    try {
      const code = readCodeFromCanvas()
      manualCode.value = code
      statusEl.textContent = `Code gelezen: ${code}. Importeren...`
      const result = await submitCode(code)
      const team = result.result?.teamName || result.result?.teamId || result.decoded?.uid || '-'
      const state = result.alreadyAnswered ? 'al gedaan' : 'opgeslagen'
      statusEl.textContent = `Gelukt: ${state} voor ${team}. Antwoord: ${result.decoded.answer}`
    } catch (error) {
      statusEl.textContent = `Niet gelukt: ${error.message}`
    }
  }

  startBtn.addEventListener('click', () => startCamera().catch((error) => {
    statusEl.textContent = `Camera fout: ${error.message}`
  }))

  scanBtn.addEventListener('click', scanFrame)
  stopBtn.addEventListener('click', stopCamera)
</script>

<%- include('../partials/page-shell-end'); %>

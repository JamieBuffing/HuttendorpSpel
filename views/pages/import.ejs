<%- include('../partials/page-shell-start', { title: 'Backup scanner' }); %>

<section class="panel">
  <h1>Backup scanner</h1>
  <p>Richt de camera op het OLED-scherm. Zorg dat de code recht en groot in het kader staat.</p>

  <% if (error) { %>
    <p class="error"><%= error %></p>
  <% } %>

  <div class="backupScanner">
    <div class="videoWrap">
      <video id="video" autoplay playsinline muted></video>
      <div class="scanFrame">
        <span>OLED in dit vak</span>
      </div>
    </div>

    <div class="buttonRow">
      <button class="button" type="button" id="startCamera">Camera starten</button>
      <button class="button" type="button" id="scanOnce">Scan één keer</button>
      <button class="button secondary" type="button" id="toggleLoop">Auto scan: uit</button>
    </div>

    <p id="scanStatus" class="helpText">Nog niet gescand.</p>

    <canvas id="workCanvas" width="128" height="64" hidden></canvas>
  </div>
</section>

<section class="panel">
  <h2>Laatste resultaat</h2>
  <pre id="resultBox" style="white-space:pre-wrap;word-break:break-word;">Geen resultaat.</pre>
</section>

<style>
.backupScanner .videoWrap{
  position:relative;
  width:min(680px,100%);
  margin:0 auto 1rem;
  background:#000;
  border-radius:16px;
  overflow:hidden;
}
.backupScanner video{
  display:block;
  width:100%;
  min-height:260px;
  background:#000;
}
.scanFrame{
  position:absolute;
  left:50%;
  top:50%;
  width:82%;
  aspect-ratio:2/1;
  transform:translate(-50%,-50%);
  border:3px solid rgba(255,255,255,.95);
  box-shadow:0 0 0 999px rgba(0,0,0,.30);
  border-radius:8px;
  pointer-events:none;
}
.scanFrame span{
  position:absolute;
  left:50%;
  bottom:-2rem;
  transform:translateX(-50%);
  font-size:.9rem;
  color:#fff;
  background:rgba(0,0,0,.65);
  padding:.25rem .5rem;
  border-radius:.5rem;
  white-space:nowrap;
}
.buttonRow{
  display:flex;
  flex-wrap:wrap;
  gap:.75rem;
  justify-content:center;
}
.secondary{opacity:.85}
</style>

<script>
(() => {
  const video = document.getElementById('video')
  const canvas = document.getElementById('workCanvas')
  const ctx = canvas.getContext('2d', { willReadFrequently: true })
  const startCameraBtn = document.getElementById('startCamera')
  const scanOnceBtn = document.getElementById('scanOnce')
  const toggleLoopBtn = document.getElementById('toggleLoop')
  const scanStatus = document.getElementById('scanStatus')
  const resultBox = document.getElementById('resultBox')

  let stream = null
  let loopEnabled = false
  let loopTimer = null

  const DATA_ROWS = [
    { x: 4, y: 4, bits: 13 },
    { x: 4, y: 13, bits: 15 },
    { x: 4, y: 22, bits: 15 },
    { x: 4, y: 31, bits: 15 },
    { x: 4, y: 40, bits: 15 },
    { x: 4, y: 49, bits: 15 }
  ]

  function setStatus(text, ok = null) {
    scanStatus.textContent = text
    scanStatus.className = ok === true ? 'helpText success' : ok === false ? 'helpText error' : 'helpText'
  }

  async function startCamera() {
    if (stream) return

    stream = await navigator.mediaDevices.getUserMedia({
      video: {
        facingMode: { ideal: 'environment' },
        width: { ideal: 1280 },
        height: { ideal: 720 }
      },
      audio: false
    })

    video.srcObject = stream
    await video.play()
    setStatus('Camera gestart. Houd het OLED-scherm in het kader.')
  }

  function cropVideoToOledCanvas() {
    if (!video.videoWidth || !video.videoHeight) {
      throw new Error('Camera is nog niet klaar')
    }

    const vw = video.videoWidth
    const vh = video.videoHeight
    const wantedRatio = 2
    let sw = vw
    let sh = Math.round(vw / wantedRatio)

    if (sh > vh) {
      sh = vh
      sw = Math.round(vh * wantedRatio)
    }

    const sx = Math.floor((vw - sw) / 2)
    const sy = Math.floor((vh - sh) / 2)

    ctx.imageSmoothingEnabled = false
    ctx.drawImage(video, sx, sy, sw, sh, 0, 0, 128, 64)

    return ctx.getImageData(0, 0, 128, 64)
  }

  function pixelScore(r, g, b) {
    const brightness = (r + g + b) / 3
    const blueScore = b * 1.25 + g * 0.35 - r * 0.25
    return Math.max(brightness, blueScore)
  }

  function sampleBlock(imageData, x, y, w, h) {
    let total = 0
    let count = 0

    for (let yy = y; yy < y + h; yy++) {
      for (let xx = x; xx < x + w; xx++) {
        if (xx < 0 || yy < 0 || xx >= 128 || yy >= 64) continue
        const i = (yy * 128 + xx) * 4
        total += pixelScore(imageData.data[i], imageData.data[i + 1], imageData.data[i + 2])
        count++
      }
    }

    return count ? total / count : 0
  }

  function readBitsFromImage(imageData) {
    const bits = []
    const scores = []

    for (const row of DATA_ROWS) {
      for (let i = 0; i < row.bits; i++) {
        const score = sampleBlock(imageData, row.x + i * 8 + 1, row.y + 1, 6, 6)
        scores.push(score)
      }
    }

    const sorted = scores.slice().sort((a, b) => a - b)
    const low = sorted[Math.floor(sorted.length * 0.20)] || 0
    const high = sorted[Math.floor(sorted.length * 0.80)] || 255
    const threshold = (low + high) / 2

    for (const score of scores) bits.push(score >= threshold ? '1' : '0')

    return { bits: bits.join(''), threshold, low, high }
  }

  async function submitBits(bits) {
    const response = await fetch('/import/scan-code', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ bits })
    })

    const data = await response.json().catch(() => ({ ok: false, error: 'Ongeldig serverantwoord' }))

    resultBox.textContent = JSON.stringify(data, null, 2)

    if (!response.ok || !data.ok) {
      throw new Error(data.error || 'Scan/import mislukt')
    }

    return data
  }

  async function scanOnce() {
    await startCamera()
    const imageData = cropVideoToOledCanvas()
    const read = readBitsFromImage(imageData)

    setStatus(`Bits gelezen. Threshold ${Math.round(read.threshold)}. Uploaden...`)

    const result = await submitBits(read.bits)
    const decoded = result.decoded || {}
    const importResult = result.importResult || {}

    if (result.alreadyAnswered) {
      setStatus(`Al gedaan: ${importResult.teamName || decoded.uid || ''}`, true)
    } else {
      setStatus(`Geïmporteerd: ${importResult.teamName || decoded.uid || ''} ${decoded.answer || ''}`, true)
    }
  }

  async function safeScanOnce() {
    try {
      await scanOnce()
      return true
    } catch (error) {
      setStatus(error.message || 'Scan mislukt', false)
      return false
    }
  }

  function setLoop(enabled) {
    loopEnabled = enabled
    toggleLoopBtn.textContent = `Auto scan: ${loopEnabled ? 'aan' : 'uit'}`

    if (loopTimer) {
      clearInterval(loopTimer)
      loopTimer = null
    }

    if (loopEnabled) {
      loopTimer = setInterval(() => safeScanOnce(), 1800)
    }
  }

  startCameraBtn.addEventListener('click', () => startCamera().catch((error) => setStatus(error.message, false)))
  scanOnceBtn.addEventListener('click', () => safeScanOnce())
  toggleLoopBtn.addEventListener('click', () => setLoop(!loopEnabled))
})()
</script>

<%- include('../partials/page-shell-end'); %>

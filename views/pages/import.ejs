<%- include('../partials/page-shell-start', { title: 'Backup import' }); %>

<section class="panel">
  <h1>Backup import</h1>
  <p>Scan de OLED-backupcode van een ESP32-box. De scanner zoekt de heldere rand, de L-marker rechtsboven en leest daarna de blauwe dataregels.</p>

  <% if (error) { %>
    <p class="error"><%= error %></p>
  <% } %>

  <div class="backupScannerGrid">
    <div>
      <div class="scannerFrame">
        <video id="cameraVideo" autoplay playsinline muted></video>
        <canvas id="workCanvas" width="320" height="180"></canvas>
        <canvas id="previewCanvas" width="128" height="64"></canvas>
        <div class="scanGuide"><span>Zoek OLED-rand + L-marker</span></div>
      </div>

      <div class="buttonRow" style="margin-top: 1rem; gap: .5rem; flex-wrap: wrap;">
        <button class="button" type="button" id="startCameraBtn">Camera starten</button>
        <button class="button secondary" type="button" id="scanOnceBtn">Scan frame</button>
        <button class="button secondary" type="button" id="toggleAutoBtn">Auto scan: uit</button>
      </div>
    </div>

    <div class="panel nestedPanel">
      <h2>Status</h2>
      <p id="scanStatus">Nog niet gescand.</p>

      <h3>Handmatig testen</h3>
      <p class="helpText">Plak hier eventueel de payload, bijvoorbeeld <code>P01R042A16BAFC2091D</code>.</p>
      <form id="manualPayloadForm" class="formStack">
        <label>Payload
          <input name="payload" id="manualPayload" placeholder="P01R..." autocomplete="off">
        </label>
        <button class="button" type="submit">Payload importeren</button>
      </form>

      <h3>Laatste decode</h3>
      <pre id="debugOutput" class="codeBlock">-</pre>
    </div>
  </div>
</section>

<style>
  .backupScannerGrid { display: grid; grid-template-columns: minmax(260px, 1.2fr) minmax(260px, .8fr); gap: 1rem; align-items: start; }
  @media (max-width: 800px) { .backupScannerGrid { grid-template-columns: 1fr; } }
  .scannerFrame { position: relative; width: min(100%, 720px); aspect-ratio: 16 / 9; background: #050505; border-radius: 16px; overflow: hidden; border: 2px solid rgba(255,255,255,.18); }
  #cameraVideo { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  #workCanvas { display: none; }
  #previewCanvas { position: absolute; right: .75rem; bottom: .75rem; width: 192px; height: 96px; image-rendering: pixelated; background: #000; border: 2px solid #00ff88; border-radius: 6px; }
  .scanGuide { position: absolute; left: 10%; right: 10%; top: 18%; bottom: 18%; border: 3px solid #00ff88; box-shadow: 0 0 0 999px rgba(0,0,0,.25); border-radius: 8px; display: flex; align-items: flex-end; justify-content: center; color: #00ff88; font-weight: 700; text-shadow: 0 1px 4px #000; padding-bottom: .4rem; pointer-events: none; }
  .nestedPanel { margin: 0; }
  .codeBlock { background: #111; color: #00ff88; padding: .75rem; border-radius: 10px; min-height: 8rem; white-space: pre-wrap; word-break: break-word; }
</style>

<script>
  const video = document.getElementById('cameraVideo')
  const workCanvas = document.getElementById('workCanvas')
  const workCtx = workCanvas.getContext('2d', { willReadFrequently: true })
  const previewCanvas = document.getElementById('previewCanvas')
  const previewCtx = previewCanvas.getContext('2d', { willReadFrequently: true })
  const startCameraBtn = document.getElementById('startCameraBtn')
  const scanOnceBtn = document.getElementById('scanOnceBtn')
  const toggleAutoBtn = document.getElementById('toggleAutoBtn')
  const scanStatus = document.getElementById('scanStatus')
  const debugOutput = document.getElementById('debugOutput')
  const manualPayloadForm = document.getElementById('manualPayloadForm')
  const manualPayload = document.getElementById('manualPayload')

  const ROWS = 6
  const DATA_X = 4
  const DATA_Y = 9
  const DATA_ROW_H = 8
  const DATA_ROW_STEP = 9
  const DATA_BIT_W = 2
  const DATA_ROW1_W = 111
  const DATA_ROW_W = 120

  let autoScan = false
  let autoTimer = null
  let stream = null
  let busy = false

  function setStatus(text, type = '') {
    scanStatus.textContent = text
    scanStatus.className = type
  }

  async function startCamera() {
    try {
      stream = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: { ideal: 'environment' }, width: { ideal: 1280 }, height: { ideal: 720 } },
        audio: false
      })
      video.srcObject = stream
      setStatus('Camera gestart. Houd de OLED-code recht, groot en scherp in beeld.')
    } catch (error) {
      setStatus('Camera starten mislukt: ' + error.message, 'error')
    }
  }

  function getRgb(data, width, x, y) {
    const idx = (y * width + x) * 4
    return [data[idx], data[idx + 1], data[idx + 2]]
  }

  function isLitRgb(r, g, b, threshold = 85) {
    const brightness = (r + g + b) / 3
    const max = Math.max(r, g, b)
    const blueEnough = b > 55 && b >= r * 0.72 && b >= g * 0.72
    const brightEnough = brightness > threshold || max > 145
    return brightEnough || blueEnough
  }

  function thresholdForImage(image) {
    const samples = []
    for (let y = 0; y < image.height; y += 3) {
      for (let x = 0; x < image.width; x += 3) {
        const [r, g, b] = getRgb(image.data, image.width, x, y)
        samples.push((r + g + b) / 3)
      }
    }
    samples.sort((a, b) => a - b)
    const dark = samples[Math.floor(samples.length * 0.40)] || 0
    const light = samples[Math.floor(samples.length * 0.96)] || 255
    return Math.max(42, Math.min(150, (dark + light) / 2))
  }

  function litAt(image, x, y, threshold) {
    if (x < 0 || y < 0 || x >= image.width || y >= image.height) return false
    const [r, g, b] = getRgb(image.data, image.width, x, y)
    return isLitRgb(r, g, b, threshold)
  }

  function sampleLitRatio(image, x, y, w, h, threshold) {
    let lit = 0
    let total = 0
    for (let yy = Math.round(y); yy < Math.round(y + h); yy++) {
      for (let xx = Math.round(x); xx < Math.round(x + w); xx++) {
        if (xx < 0 || yy < 0 || xx >= image.width || yy >= image.height) continue
        total++
        if (litAt(image, xx, yy, threshold)) lit++
      }
    }
    return total ? lit / total : 0
  }

  function findBrightBox(image) {
    const w = image.width
    const h = image.height
    const threshold = thresholdForImage(image)
    let minX = w, minY = h, maxX = 0, maxY = 0, count = 0

    for (let y = 0; y < h; y++) {
      for (let x = 0; x < w; x++) {
        if (litAt(image, x, y, threshold)) {
          minX = Math.min(minX, x)
          minY = Math.min(minY, y)
          maxX = Math.max(maxX, x)
          maxY = Math.max(maxY, y)
          count++
        }
      }
    }

    if (count < 80) return null

    let boxW = maxX - minX + 1
    let boxH = maxY - minY + 1
    const cx = (minX + maxX) / 2
    const cy = (minY + maxY) / 2
    const targetRatio = 2
    const ratio = boxW / Math.max(1, boxH)

    if (ratio > targetRatio) boxH = boxW / targetRatio
    else boxW = boxH * targetRatio

    boxW *= 1.10
    boxH *= 1.16

    minX = Math.max(0, Math.round(cx - boxW / 2))
    maxX = Math.min(w - 1, Math.round(cx + boxW / 2))
    minY = Math.max(0, Math.round(cy - boxH / 2))
    maxY = Math.min(h - 1, Math.round(cy + boxH / 2))

    return { x: minX, y: minY, w: maxX - minX + 1, h: maxY - minY + 1, threshold }
  }

  function normalizeFrameFromCamera() {
    if (!video.videoWidth || !video.videoHeight) return null

    workCanvas.width = 360
    workCanvas.height = 202
    workCtx.drawImage(video, 0, 0, workCanvas.width, workCanvas.height)
    const image = workCtx.getImageData(0, 0, workCanvas.width, workCanvas.height)
    const box = findBrightBox(image)
    if (!box) throw new Error('Geen heldere OLED-rand gevonden')

    previewCtx.imageSmoothingEnabled = false
    previewCtx.fillStyle = 'black'
    previewCtx.fillRect(0, 0, 128, 64)
    previewCtx.drawImage(workCanvas, box.x, box.y, box.w, box.h, 0, 0, 128, 64)

    return previewCtx.getImageData(0, 0, 128, 64)
  }

  function markerLooksRight(image) {
    const threshold = thresholdForImage(image)
    const topLine = sampleLitRatio(image, 117, 2, 9, 2, threshold)
    const leftLine = sampleLitRatio(image, 117, 2, 2, 9, threshold)
    return topLine > 0.38 && leftLine > 0.38
  }

  function bitCell(image, x, y, w, h, threshold) {
    // Data is blauw/licht, achtergrond zwart. We gebruiken een hele cel,
    // zodat onscherpte en OLED-blooming minder problemen geven.
    return sampleLitRatio(image, x, y, w, h, threshold) > 0.28 ? '1' : '0'
  }

  function readBitStreamFromNormalized(image) {
    const threshold = thresholdForImage(image)

    if (!markerLooksRight(image)) {
      throw new Error('L-marker rechtsboven niet gevonden. Houd de code rechtop en tik om scherp te stellen.')
    }

    let bits = ''

    for (let row = 0; row < ROWS; row++) {
      const rowWidth = row === 0 ? DATA_ROW1_W : DATA_ROW_W
      const cells = Math.floor(rowWidth / DATA_BIT_W)
      const y = DATA_Y + row * DATA_ROW_STEP

      for (let i = 0; i < cells; i++) {
        const x = DATA_X + i * DATA_BIT_W
        bits += bitCell(image, x, y, DATA_BIT_W, DATA_ROW_H, threshold)
      }
    }

    return bits
  }

  function scanBitsFromFrame() {
    const normalized = normalizeFrameFromCamera()
    if (!normalized) return null
    return readBitStreamFromNormalized(normalized)
  }

  async function sendToServer(payload) {
    const response = await fetch('/import/scan-code', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })
    const json = await response.json().catch(() => ({ ok: false, error: 'Ongeldig serverantwoord' }))
    debugOutput.textContent = JSON.stringify(json, null, 2)
    if (!response.ok || !json.ok) throw new Error(json.error || 'Import mislukt')
    return json
  }

  async function scanOnce() {
    if (busy) return
    busy = true
    try {
      const rawBits = scanBitsFromFrame()
      if (!rawBits) throw new Error('Geen codebits gevonden')
      const json = await sendToServer({ rawBits })
      const decoded = json.decoded || {}
      setStatus(`Gelukt: ${decoded.postId || '-'} / ${decoded.uid || '-'} / ${decoded.answer || '-'}`, 'success')
      setAutoScan(false)
    } catch (error) {
      setStatus(error.message, 'error')
    } finally {
      busy = false
    }
  }

  function setAutoScan(enabled) {
    autoScan = enabled
    toggleAutoBtn.textContent = 'Auto scan: ' + (autoScan ? 'aan' : 'uit')
    if (autoTimer) clearInterval(autoTimer)
    autoTimer = null
    if (autoScan) autoTimer = setInterval(scanOnce, 900)
  }

  startCameraBtn.addEventListener('click', startCamera)
  scanOnceBtn.addEventListener('click', scanOnce)
  toggleAutoBtn.addEventListener('click', () => setAutoScan(!autoScan))

  manualPayloadForm.addEventListener('submit', async (event) => {
    event.preventDefault()
    try {
      const json = await sendToServer({ payload: manualPayload.value })
      const decoded = json.decoded || {}
      setStatus(`Gelukt: ${decoded.postId || '-'} / ${decoded.uid || '-'} / ${decoded.answer || '-'}`, 'success')
    } catch (error) {
      setStatus(error.message, 'error')
    }
  })
</script>

<%- include('../partials/page-shell-end'); %>

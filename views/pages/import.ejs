<%- include('../partials/page-shell-start', { title: 'Backup scanner' }); %>

<section class="panel">
  <h1>Backup scanner</h1>
  <p>Richt de camera op de OLED-code. De scanner leest de vaste witte pixelmap en de blauwe 8×8 databits.</p>

  <div class="scannerGrid">
    <div>
      <video id="video" autoplay playsinline muted style="width:100%;max-width:520px;border-radius:16px;background:#000;"></video>
      <canvas id="canvas" width="640" height="360" style="display:none"></canvas>
      <canvas id="debug" width="128" height="64" style="width:384px;height:192px;image-rendering:pixelated;background:#000;border:2px solid #444;margin-top:10px;"></canvas>
    </div>
    <div>
      <p id="status" class="helpText">Camera nog niet gestart.</p>
      <p><strong>Payload:</strong><br><code id="payload">-</code></p>
      <p><strong>Decode:</strong><br><code id="decoded">-</code></p>
      <button class="button" type="button" id="startBtn">Start camera</button>
      <button class="button" type="button" id="scanBtn">Scan frame</button>
      <button class="button" type="button" id="submitBtn" disabled>Importeer antwoord</button>
    </div>
  </div>
</section>


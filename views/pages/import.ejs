<%- include('../partials/page-shell-start', { title: 'Backup import' }); %>

<section class="panel">
  <h1>Backup import</h1>
  <p>Scan hier de 6-regel OLED-backupcode van een ESP32-box. Houd de witte rand op het OLED-scherm zo recht mogelijk binnen het kader.</p>

  <% if (error) { %>
    <p class="error"><%= error %></p>
  <% } %>

  <div class="backupScannerGrid">
    <div>
      <div class="scannerFrame">
        <video id="cameraVideo" autoplay playsinline muted></video>
        <canvas id="scanCanvas" width="128" height="64"></canvas>
        <div class="scanGuide"><span>OLED hier</span></div>
      </div>

      <div class="buttonRow" style="margin-top: 1rem; gap: .5rem; flex-wrap: wrap;">
        <button class="button" type="button" id="startCameraBtn">Camera starten</button>
        <button class="button secondary" type="button" id="scanOnceBtn">Scan frame</button>
        <button class="button secondary" type="button" id="toggleAutoBtn">Auto scan: uit</button>
      </div>
    </div>

    <div class="panel nestedPanel">
      <h2>Status</h2>
      <p id="scanStatus">Nog niet gescand.</p>

      <h3>Handmatig testen</h3>
      <p class="helpText">Je kunt hier ook direct een payload plakken, bijvoorbeeld <code>P01R042A16BAFC2091D</code>.</p>
      <form id="manualPayloadForm" class="formStack">
        <label>Payload
          <input name="payload" id="manualPayload" placeholder="P01R..." autocomplete="off">
        </label>
        <button class="button" type="submit">Payload importeren</button>
      </form>

      <h3>Laatste decode</h3>
      <pre id="debugOutput" class="codeBlock">-</pre>
    </div>
  </div>
</section>

<% if (result && result.legacy) { %>
  <section class="panel">
    <h2>Import resultaat</h2>
    <p><%= result.count %> object(en) verwerkt.</p>
  </section>
<% } %>

<style>
  .backupScannerGrid {
    display: grid;
    grid-template-columns: minmax(260px, 1.2fr) minmax(260px, .8fr);
    gap: 1rem;
    align-items: start;
  }

  @media (max-width: 800px) {
    .backupScannerGrid { grid-template-columns: 1fr; }
  }

  .scannerFrame {
    position: relative;
    width: min(100%, 720px);
    aspect-ratio: 2 / 1;
    background: #050505;
    border-radius: 16px;
    overflow: hidden;
    border: 2px solid rgba(255,255,255,.18);
  }

  #cameraVideo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #scanCanvas { display: none; }

  .scanGuide {
    position: absolute;
    left: 8%;
    right: 8%;
    top: 10%;
    bottom: 10%;
    border: 3px solid #00ff88;
    box-shadow: 0 0 0 999px rgba(0,0,0,.35);
    border-radius: 8px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    color: #00ff88;
    font-weight: 700;
    text-shadow: 0 1px 4px #000;
    padding-bottom: .4rem;
    pointer-events: none;
  }

  .nestedPanel { margin: 0; }

  .codeBlock {
    background: #111;
    color: #00ff88;
    padding: .75rem;
    border-radius: 10px;
    min-height: 7rem;
    white-space: pre-wrap;
    word-break: break-word;
  }
</style>

<script>
  const video = document.getElementById('cameraVideo')
  const canvas = document.getElementById('scanCanvas')
  const ctx = canvas.getContext('2d', { willReadFrequently: true })
  const startCameraBtn = document.getElementById('startCameraBtn')
  const scanOnceBtn = document.getElementById('scanOnceBtn')
  const toggleAutoBtn = document.getElementById('toggleAutoBtn')
  const scanStatus = document.getElementById('scanStatus')
  const debugOutput = document.getElementById('debugOutput')
  const manualPayloadForm = document.getElementById('manualPayloadForm')
  const manualPayload = document.getElementById('manualPayload')

  let autoScan = false
  let autoTimer = null
  let stream = null
  let busy = false

  function setStatus(text, type = '') {
    scanStatus.textContent = text
    scanStatus.className = type
  }

  async function startCamera() {
    try {
      stream = await navigator.mediaDevices.getUserMedia({
        video: {
          facingMode: { ideal: 'environment' },
          width: { ideal: 1280 },
          height: { ideal: 720 }
        },
        audio: false
      })
      video.srcObject = stream
      setStatus('Camera gestart. Houd de OLED-code binnen het groene kader.')
    } catch (error) {
      setStatus('Camera starten mislukt: ' + error.message, 'error')
    }
  }

  function thresholdRowsFromFrame() {
    if (!video.videoWidth || !video.videoHeight) return null

    const vw = video.videoWidth
    const vh = video.videoHeight

    // Zelfde kader als de groene overlay: 84% breed, 80% hoog, 2:1 verhouding.
    let cropW = Math.floor(vw * 0.84)
    let cropH = Math.floor(cropW / 2)

    if (cropH > vh * 0.80) {
      cropH = Math.floor(vh * 0.80)
      cropW = Math.floor(cropH * 2)
    }

    const sx = Math.floor((vw - cropW) / 2)
    const sy = Math.floor((vh - cropH) / 2)

    ctx.drawImage(video, sx, sy, cropW, cropH, 0, 0, 128, 64)
    const image = ctx.getImageData(0, 0, 128, 64)
    const data = image.data

    function brightness(x, y) {
      const idx = (y * 128 + x) * 4
      return (data[idx] + data[idx + 1] + data[idx + 2]) / 3
    }

    // Dynamische drempel op basis van het OLED-cropbeeld.
    const samples = []
    for (let y = 0; y < 64; y += 2) {
      for (let x = 0; x < 128; x += 2) samples.push(brightness(x, y))
    }
    samples.sort((a, b) => a - b)
    const dark = samples[Math.floor(samples.length * 0.25)] || 0
    const light = samples[Math.floor(samples.length * 0.90)] || 255
    const threshold = Math.max(40, Math.min(220, (dark + light) / 2))

    const rows = []

    for (let row = 0; row < 6; row++) {
      const y = 3 + row * 9 + 3
      let bits = ''

      // Arduino tekent vanaf x=6; server probeert zelf payloadlengtes en blokbreedte.
      for (let x = 6; x < 122; x++) {
        let sum = 0
        let count = 0
        for (let yy = y - 2; yy <= y + 2; yy++) {
          if (yy >= 0 && yy < 64) {
            sum += brightness(x, yy)
            count++
          }
        }
        bits += (sum / Math.max(1, count)) > threshold ? '1' : '0'
      }

      rows.push(bits)
    }

    return rows
  }

  async function sendToServer(payload) {
    const response = await fetch('/import/scan-code', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })

    const json = await response.json().catch(() => ({ ok: false, error: 'Ongeldig serverantwoord' }))

    debugOutput.textContent = JSON.stringify(json, null, 2)

    if (!response.ok || !json.ok) {
      throw new Error(json.error || 'Import mislukt')
    }

    return json
  }

  async function scanOnce() {
    if (busy) return
    busy = true

    try {
      const rawRows = thresholdRowsFromFrame()
      if (!rawRows) throw new Error('Geen camerabeeld beschikbaar')

      const json = await sendToServer({ rawRows })
      const decoded = json.decoded || {}
      setStatus(`Gelukt: ${decoded.postId || '-'} / ${decoded.uid || '-'} / ${decoded.answer || '-'}`, 'success')
    } catch (error) {
      setStatus(error.message, 'error')
    } finally {
      busy = false
    }
  }

  function setAutoScan(enabled) {
    autoScan = enabled
    toggleAutoBtn.textContent = 'Auto scan: ' + (autoScan ? 'aan' : 'uit')

    if (autoTimer) clearInterval(autoTimer)
    autoTimer = null

    if (autoScan) {
      autoTimer = setInterval(scanOnce, 1200)
    }
  }

  startCameraBtn.addEventListener('click', startCamera)
  scanOnceBtn.addEventListener('click', scanOnce)
  toggleAutoBtn.addEventListener('click', () => setAutoScan(!autoScan))

  manualPayloadForm.addEventListener('submit', async (event) => {
    event.preventDefault()
    try {
      const json = await sendToServer({ payload: manualPayload.value })
      const decoded = json.decoded || {}
      setStatus(`Gelukt: ${decoded.postId || '-'} / ${decoded.uid || '-'} / ${decoded.answer || '-'}`, 'success')
    } catch (error) {
      setStatus(error.message, 'error')
    }
  })
</script>

<%- include('../partials/page-shell-end'); %>

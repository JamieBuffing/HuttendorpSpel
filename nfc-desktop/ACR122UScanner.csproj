<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>Huttendorp de Meent NFC Scanner</AssemblyName>
    <RootNamespace>ACR122UScanner</RootNamespace>
    <ApplicationIcon>assets\favicon.ico</ApplicationIcon>
    <Company>Huttendorp de Meent</Company>
    <Product>Huttendorp de Meent NFC Scanner</Product>
    <Title>Huttendorp de Meent NFC Scanner</Title>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="assets\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
</Project>
